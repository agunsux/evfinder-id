# --- APP ENVIRONMENT ---
PORT=3000
NODE_ENV=development
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# --- FIREBASE CLIENT CONFIG (VITE) ---
# All variables starting with VITE_ are exposed to the browser.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=practical-gecko-476621-q4
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DB_ID=

# --- FIREBASE ADMIN SDK (SERVER) ---
# These are private and only used on the backend.
FIREBASE_PROJECT_ID=practical-gecko-476621-q4
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: Private key must be quoted and internal newlines represented as \n
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEv... \n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- OTHER SERVICES ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# --- TTS / External Provider CONFIGURATION ---
TTS_PROVIDER=google  # options: google, openai, antigravity
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com
OPENAI_TTS_MODEL=gpt-4o-mini-tts
ANTIGRAVITY_API_URL=
ANTIGRAVITY_API_KEY=

# --- CLOUD DEPLOYMENT (GitHub Actions / Cloud Run) ---
# These values are stored in GitHub Secrets, not in .env for production.
# GCP_PROJECT_ID
# GCP_SA_KEY
# CLOUD_RUN_SERVICE
# CLOUD_RUN_REGION
