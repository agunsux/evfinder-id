rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitive Definitions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Phase 4: Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'tier']) &&
             data.id is string && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.tier is string && data.tier.size() <= 32 &&
             (!('name' in data) || (data.name is string && data.name.size() <= 128)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() <= 32)) &&
             (!('referral_code' in data) || (data.referral_code is string && data.referral_code.size() <= 32)) &&
             (!('referred_by' in data) || (data.referred_by is string || data.referred_by == null)) &&
             (!('bonus_credits' in data) || (data.bonus_credits is list)) &&
             (!('used_chars' in data) || (data.used_chars is int && data.used_chars >= 0)) &&
             (!('valid_referrals' in data) || (data.valid_referrals is int)) &&
             (!('has_triggered_ref' in data) || (data.has_triggered_ref is bool)) &&
             (!('ips_used' in data) || (data.ips_used is list))
             ;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['date', 'character_count', 'voice', 'credits_used']) &&
             data.date is int &&
             data.character_count is int && data.character_count >= 0 &&
             data.voice is string && data.voice.size() <= 128 &&
             data.credits_used is int && data.credits_used >= 0;
    }

    // --- Phase 4: Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 

      allow create: if isOwner(userId) && isVerified() && isValidUser(incoming()) && 
                       incoming().tier == 'FREE' && 
                       incoming().used_chars == 0;

      allow update: if (isOwner(userId) && isVerified() && isValidUser(incoming()) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'whatsapp', 'whatsapp_opted_in', 'email_subscribed', 'pronunciations'])) ||
        // Action: Usage tracking
        (incoming().diff(existing()).affectedKeys().hasOnly(['used_chars', 'generation_count', 'last_generation_at', 'has_triggered_ref']) && 
         incoming().used_chars >= existing().used_chars)
      )) || isAdmin();

      // Sub-collection: History
      match /history/{historyId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        
        allow create: if isOwner(userId) && isVerified() && isValidHistory(incoming()) && isValidId(historyId);
        allow update, delete: if isAdmin();
      }
    }

    match /config/voice {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false; 
    }
  }
}
