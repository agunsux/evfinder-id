rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.currentQuota is int &&
             data.maxQuota is int;
    }

    function isValidScript(data) {
      return data.userId is string &&
             data.content is string;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['currentQuota', 'rolloverQuota', 'updatedAt', 'isNewsletterSubscribed', 'plan', 'maxQuota'])
      );
    }

    match /scripts/{scriptId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidScript(request.resource.data);
    }
  }
}
