{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with referral info and credits.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "emailVerified": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "creditBalance": { "type": "number" },
        "totalCreditsPurchased": { "type": "number" },
        "totalCreditsEarnedReferral": { "type": "number" },
        "totalCreditsEarnedSocial": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "firstGenerationDone": { "type": "boolean" }
      }
    },
    "Referral": {
      "title": "Referral",
      "description": "Referral tracking.",
      "type": "object",
      "properties": {
        "referrerUid": { "type": "string" },
        "refereeUid": { "type": "string" },
        "referralCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "flagged", "rejected", "limit_reached"] },
        "ipHash": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "completedAt": { "type": "timestamp" },
        "bonusAwarded": { "type": "number" },
        "month": { "type": "string" }
      }
    },
    "SocialClaim": {
      "title": "SocialClaim",
      "description": "Social media post reward claim.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "platform": { "type": "string", "enum": ["instagram", "tiktok"] },
        "postUrl": { "type": "string" },
        "urlHash": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_review", "approved", "rejected"] },
        "submittedAt": { "type": "timestamp" },
        "reviewedAt": { "type": "timestamp" },
        "reviewedBy": { "type": "string" },
        "rejectionReason": { "type": "string" },
        "bonusAwarded": { "type": "number" },
        "month": { "type": "string" }
      }
    },
    "CreditTransaction": {
      "title": "CreditTransaction",
      "description": "Log of credit changes.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["purchase", "referral_bonus", "social_bonus", "usage", "welcome_bonus"] },
        "amount": { "type": "number" },
        "balanceAfter": { "type": "number" },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "description": { "type": "string" }
      }
    }
    ,"TTSGeneration": {
      "title": "TTSGeneration",
      "description": "Tracking for AI voice generation usage.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "text": { "type": "string" },
        "voiceModel": { "type": "string" },
        "charCount": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "audioUrl": { "type": "string" }
      }
    },
    "PronunciationRule": {
      "title": "PronunciationRule",
      "description": "Custom word-pronunciation pairs for a user.",
      "type": "object",
      "properties": {
        "originalWord": { "type": "string" },
        "pronunciation": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["originalWord", "pronunciation", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles." },
    "/referrals/{referralId}": { "schema": "Referral", "description": "Referral tracking records." },
    "/socialClaims/{claimId}": { "schema": "SocialClaim", "description": "Social media claim records." },
    "/creditTransactions/{txId}": { "schema": "CreditTransaction", "description": "Credit history." },
    "/users/{uid}/tts_generations/{genId}": { "schema": "TTSGeneration", "description": "Audio generation history." },
    "/users/{uid}/pronunciation_rules/{ruleId}": { "schema": "PronunciationRule", "description": "Custom pronunciation rules for a specific user." }
  }
}
