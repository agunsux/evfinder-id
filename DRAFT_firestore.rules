rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Global Default Deny
    match /{document=**} { allow read, write: if false; }

    // User Collection
    match /users/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow update: if isOwner(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['creditBalance', 'totalCreditsPurchased', 'totalCreditsEarnedReferral', 'totalCreditsEarnedSocial', 'firstGenerationDone']);
    }

    // Referral Collection
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (resource.data.referrerUid == request.auth.uid || resource.data.refereeUid == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && request.resource.data.referrerUid != request.auth.uid; // Basic self-referral block
    }

    // Social Claims
    match /socialClaims/{claimId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin(); // Only allow admin to update status, bonus, etc.
    }
  }
}
